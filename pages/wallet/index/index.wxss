.container {
  padding: 30rpx;
  background: #f4f4f4;
  min-height: 100vh;
  box-sizing: border-box;
}

.wallet-card {
  background: #fbc346;
  border-radius: 20rpx;
  padding: 50rpx;
  color: #fff;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(251, 195, 70, 0.4);
  margin-bottom: 60rpx;
}

.title {
  font-size: 32rpx;
  opacity: 0.9;
}

.balance {
  font-size: 80rpx;
  font-weight: bold;
  margin: 30rpx 0;
}

.frozen {
  font-size: 28rpx;
  opacity: 0.8;
}

.action-bar {
  display: flex;
  justify-content: space-between;
}

.btn {
  width: 45%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
}

.btn-recharge {
  background: #09bb07;
  color: #fff;
}

.btn-withdraw {
  background: #fff;
  color: #333;
  border: 1rpx solid #ddd;
}

.tips {
  margin-top: 80rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
  color: #666;
  font-size: 26rpx;
  line-height: 1.8;
}