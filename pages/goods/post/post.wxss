.container {
  box-sizing: border-box;
  padding: 30rpx;
  background: #f4f4f4;
  min-height: 100vh;
}

.form-group {
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.input, .picker {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #eee;
}

.textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  margin-top: 10rpx;
}

.tips {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-top: 30rpx;
  margin-bottom: 50rpx;
}

.submit-btn {
  background: #fbc346;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
}