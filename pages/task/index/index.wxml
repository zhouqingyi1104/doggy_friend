<view class="container">
  <view class="task-list">
    <view class="task-item" wx:for="{{tasks}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="header">
        <view class="title">{{item.title}}</view>
        <view class="price">￥{{item.price}}</view>
      </view>
      <view class="content">
        <text class="desc">{{item.description}}</text>
      </view>
      <view class="footer">
        <view class="user-info">
          <image src="{{item.buyer.avatar || '/image/default_avatar.png'}}" class="avatar"></image>
          <text class="nickname">{{item.buyer.nickname}}</text>
          <text class="credit">信誉分: {{item.buyer.credit_score}}</text>
        </view>
        <view class="status {{item.status === 1 ? 'status-waiting' : ''}}">
          {{item.status === 1 ? '待接单' : (item.status === 2 ? '进行中' : (item.status === 3 ? '已完成' : '已取消'))}}
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{tasks.length === 0}}">
    暂无任务数据
  </view>

  <view class="post-btn" bindtap="goPost">
    <image src="/image/v2/post.png" class="post-icon"></image>
  </view>
</view>