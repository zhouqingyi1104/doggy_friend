<view class="container">
  <view class="tabs">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">我发布的</view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">我接取的</view>
  </view>

  <view class="task-list">
    <view class="task-item" wx:for="{{tasks}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="header">
        <view class="title">{{item.title}}</view>
        <view class="price">￥{{item.price}}</view>
      </view>
      <view class="content">
        <text class="desc">{{item.description}}</text>
      </view>
      <view class="footer">
        <text class="date-time">{{item.created_at}}</text>
        <view class="status {{item.status === 1 ? 'status-waiting' : (item.status === 2 ? 'status-working' : (item.status === 3 ? 'status-completed' : ''))}}">
          {{item.status === 1 ? '待接单' : (item.status === 2 ? '进行中' : (item.status === 3 ? '已完成' : '已取消'))}}
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{tasks.length === 0}}">
    暂无任务数据
  </view>
</view>